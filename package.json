{
  "name": "express-js-chart",
  "displayName": "Express JS Chart",
  "description": "Express JS routes, endpoints and middlewares in a diagram",
  "publisher": "MarcoArruda",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:**/package.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "expressJsChart",
          "title": "Express JS Chart Observer",
          "icon": "media/observer.svg"
        }
      ]
    },
    "views": {
      "expressJsChart": [
        {
          "id": "expressJsChart.endpoints",
          "name": "Endpoints",
          "icon": "media/observer.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "expressJsChart.openDiagram",
        "title": "Open Diagram",
        "icon": {
          "light": "media/open-diagram.svg",
          "dark": "media/open-diagram.svg"
        }
      },
      {
        "command": "expressJsChart.refreshDiagram",
        "title": "Refresh Diagram",
        "icon": {
          "light": "media/refresh-diagram.svg",
          "dark": "media/refresh-diagram.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "expressJsChart.openDiagram",
          "when": "view == expressJsChart.endpoints",
          "group": "navigation"
        },
        {
          "command": "expressJsChart.refreshDiagram",
          "when": "view == expressJsChart.endpoints",
          "group": "navigation@1"
        }
      ]
    }
  },
  "scripts": {
    "build:extension": "esbuild src/extension.ts --bundle --platform=node --external:vscode --external:typescript --outfile=dist/extension.js",
    "build:webview": "vite build --config media/webview/vite.config.ts",
    "build": "npm run build:webview && npm run build:extension",
    "watch:webview": "vite build --watch --config media/webview/vite.config.ts",
    "watch:extension": "esbuild src/extension.ts --bundle --platform=node --external:vscode --external:typescript --outfile=dist/extension.js --watch",
    "watch": "concurrently -c yellow,cyan \"npm:watch:webview\" \"npm:watch:extension\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "vite": "^7.0.0",
    "vscode": "^1.1.37",
    "vsce": "^2.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcoarruda/express-api-chart.git"
  },
  "dependencies": {
    "mermaid": "^11.14.0",
    "typescript": "^5.8.0"
  }
}
